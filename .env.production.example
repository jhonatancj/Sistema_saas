# Copiar a .env.production y completar con valores reales antes de
# desplegar (`cp .env.production.example .env.production`). Nunca commitear
# .env.production con secretos reales — .gitignore ya cubre .env/.env.*.local,
# pero .env.production NO tiene el sufijo .local, así que hay que tener
# cuidado de no agregarlo a git a mano.

# ── Base de datos ────────────────────────────────────────────────────
DB_NAME=saas_inventario
DB_USER=saas_user
DB_PASSWORD=CAMBIAR_por_una_contrasena_fuerte_real

# ── Auth ──────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_ACCESS_SECRET=CAMBIAR_generar_con_openssl_rand_base64_48
JWT_ACCESS_EXPIRATION=15m

# ── CORS / dominio ────────────────────────────────────────────────────
# Dominio real de producción, SIN protocolo ni subdominio (ej. "miapp.com")
# — main.ts arma el regex de CORS como `\.${CORS_DOMAIN}$`, matchea
# cualquier subdominio de tenant (ej. acme.miapp.com) automáticamente.
CORS_DOMAIN=CAMBIAR_ejemplo.com
